# Copy this file to .env for local development.
# Do not commit .env.

# Supabase configuration (required)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Optional: enables AES-256 encrypted local fallback when OS keychain is unavailable.
AUVRO_FALLBACK_PASSPHRASE=change_me_to_a_long_random_value

# App AI configuration (placeholder while AI provider integration is in progress)
AUVRO_ENDPOINT=https://api.example.com/v1/chat
AUVRO_MODEL=gpt-4-mini
