# Copy this file to .env for local development.
# Do not commit .env.

# Supabase configuration (required)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# HackClub AI configuration
AUVRO_API_KEY=your_hackclub_api_key_here
AUVRO_ENDPOINT=https://ai.hackclub.com/proxy/v1
AUVRO_MODEL=openai/gpt-oss-120b

# OpenRouter AI configuration (optional; takes precedence over HackClub when set)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-120b:free
# OPENROUTER_SITE_URL=https://www.anupsharma12.com.np
# OPENROUTER_APP_NAME=AuvroAI
