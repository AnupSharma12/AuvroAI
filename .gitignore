# Rust build output
/target/

# Backup files generated by rustfmt
**/*.rs.bk

# Environment and local secrets
.env
.env.*
!.env.example

# Logs and temp files
*.log
*.tmp
*.temp

# OS files
.DS_Store
Thumbs.db

# Editor/IDE settings
.idea/
.vscode/
*.swp
*.swo

# Coverage and profiling output
coverage/
*.profraw
*.profdata

# Local sqlite/db artifacts (if used for dev history/cache)
*.db
*.sqlite
*.sqlite3

# Binary release artifacts and archives
dist/
release/
*.zip
*.tar
*.tar.gz
*.tgz
